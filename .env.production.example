# Cospan Production Environment
# Copy to .env.production and fill in all values

# Image version (defaults to latest)
# COSPAN_VERSION=0.2.0

# Domain (required) - point DNS A record at your server IP
DOMAIN=cospan.dev

# Database password (required) - generate with: openssl rand -base64 32
POSTGRES_PASSWORD=

# Node DID (required) - your ATProto DID for the node operator
# Get yours from: https://bsky.app/profile/yourhandle -> Settings -> DID
NODE_DID=did:plc:your-did-here
