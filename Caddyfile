# Production reverse proxy with automatic TLS via Let's Encrypt.

cospan.dev {
	# AppView endpoints (more specific paths first)
	handle /xrpc/* {
		reverse_proxy localhost:3000
	}
	handle /oauth/* {
		reverse_proxy localhost:3000
	}
	handle /.well-known/jwks.json {
		reverse_proxy localhost:3000
	}

	# Frontend (SvelteKit) catches everything else
	handle {
		reverse_proxy localhost:3002
	}
}

node.cospan.dev {
	handle /xrpc/* {
		reverse_proxy localhost:3001
	}
	# Git smart HTTP protocol
	handle {
		reverse_proxy localhost:3001
	}
}
