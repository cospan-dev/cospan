{
  "$type": "panproto.protolens",
  "id": "dev.cospan.org.db-projection",
  "source": "dev.cospan.org",
  "target": "dev.cospan.org.view",
  "steps": [
    {
      "remove_field": "avatar"
    },
    {
      "add_field": {
        "name": "avatarCid",
        "kind": "string",
        "default": null,
        "expr": "field (field avatar \"ref\") \"$link\""
      }
    }
  ],
  "extensions": {
    "table": {
      "name": "orgs",
      "row_struct": "OrgRow",
      "conflict_keys": [
        "did",
        "rkey"
      ]
    }
  }
}
