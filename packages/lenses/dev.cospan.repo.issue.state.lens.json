{
  "$type": "panproto.protolens",
  "id": "dev.cospan.repo.issue.state.db-projection",
  "description": "Lexicon \u2192 appview DB projection for issue state changes",
  "source": "dev.cospan.repo.issue.state",
  "target": "dev.cospan.repo.issue.state.view",
  "steps": [
    {
      "rename_field": {
        "old": "issue",
        "new": "issueUri"
      }
    }
  ],
  "extensions": {
    "table": {
      "name": "issue_states",
      "row_struct": "IssueStateRow",
      "conflict_keys": [
        "did",
        "rkey"
      ]
    }
  }
}
