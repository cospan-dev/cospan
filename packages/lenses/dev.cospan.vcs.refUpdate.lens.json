{
  "$type": "panproto.protolens",
  "id": "dev.cospan.vcs.refUpdate.db-projection",
  "description": "Lexicon → appview DB projection for ref updates",
  "source": "dev.cospan.vcs.refUpdate",
  "target": "dev.cospan.vcs.refUpdate.view",
  "steps": [
    { "remove_field": "repo" },
    { "remove_field": "breakingChanges" },
    {
      "add_field": {
        "name": "repoDid",
        "kind": "string",
        "default": "",
        "expr": "head(split(replace(repo, 'at://', ''), '/'))"
      }
    },
    {
      "add_field": {
        "name": "repoName",
        "kind": "string",
        "default": "",
        "expr": "index(split(replace(repo, 'at://', ''), '/'), 2)"
      }
    },
    {
      "add_field": {
        "name": "breakingChangeCount",
        "kind": "integer",
        "default": 0,
        "expr": "len(breakingChanges)"
      }
    },
    {
      "add_field": {
        "name": "commitCount",
        "kind": "integer",
        "default": 0
      }
    }
  ],
  "table": {
    "name": "ref_updates",
    "row_struct": "RefUpdateRow",
    "conflict_keys": ["committer_did", "rkey"],
    "has_serial_id": true,
    "include_did": false,
    "column_defaults": {
      "breakingChangeCount": "0",
      "commitCount": "0"
    },
    "counter_fields": ["breakingChangeCount"]
  }
}
