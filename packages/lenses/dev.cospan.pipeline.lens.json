{
  "$type": "panproto.protolens",
  "id": "dev.cospan.pipeline.db-projection",
  "source": "dev.cospan.pipeline",
  "target": "dev.cospan.pipeline.view",
  "steps": [
    {
      "remove_field": "repo"
    },
    {
      "remove_field": "algebraicChecks"
    },
    {
      "add_field": {
        "name": "repoDid",
        "kind": "string",
        "default": "",
        "expr": "head (split (replace repo \"at://\" \"\") \"/\")"
      }
    },
    {
      "add_field": {
        "name": "repoName",
        "kind": "string",
        "default": "",
        "expr": "head (tail (tail (split (replace repo \"at://\" \"\") \"/\")))"
      }
    },
    {
      "add_field": {
        "name": "status",
        "kind": "string",
        "default": "pending"
      }
    },
    {
      "add_field": {
        "name": "gatTypeCheck",
        "kind": "string",
        "default": null,
        "expr": "field algebraicChecks \"gatTypeCheck\""
      }
    },
    {
      "add_field": {
        "name": "equationVerification",
        "kind": "string",
        "default": null,
        "expr": "field algebraicChecks \"equationVerification\""
      }
    },
    {
      "add_field": {
        "name": "lensLawCheck",
        "kind": "string",
        "default": null,
        "expr": "field algebraicChecks \"lensLawCheck\""
      }
    },
    {
      "add_field": {
        "name": "breakingChangeCheck",
        "kind": "string",
        "default": null,
        "expr": "field algebraicChecks \"breakingChangeCheck\""
      }
    }
  ],
  "extensions": {
    "table": {
      "name": "pipelines",
      "row_struct": "PipelineRow",
      "conflict_keys": [
        "did",
        "rkey"
      ],
      "column_defaults": {
        "status": "'pending'"
      }
    }
  }
}
