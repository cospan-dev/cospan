{
  "$type": "panproto.protolens",
  "id": "dev.cospan.pipeline.db-projection",
  "source": "dev.cospan.pipeline",
  "target": "dev.cospan.pipeline.view",
  "steps": [
    { "remove_field": "repo" },
    { "remove_field": "algebraicChecks" },
    {
      "add_field": {
        "name": "repoDid",
        "kind": "string",
        "default": "",
        "expr": "head(split(replace(repo, 'at://', ''), '/'))"
      }
    },
    {
      "add_field": {
        "name": "repoName",
        "kind": "string",
        "default": "",
        "expr": "index(split(replace(repo, 'at://', ''), '/'), 2)"
      }
    },
    {
      "add_field": {
        "name": "status",
        "kind": "string",
        "default": "pending"
      }
    },
    {
      "add_field": {
        "name": "gatTypeCheck",
        "kind": "string",
        "default": null,
        "expr": "path_extract(algebraicChecks, ['gatTypeCheck'])"
      }
    },
    {
      "add_field": {
        "name": "equationVerification",
        "kind": "string",
        "default": null,
        "expr": "path_extract(algebraicChecks, ['equationVerification'])"
      }
    },
    {
      "add_field": {
        "name": "lensLawCheck",
        "kind": "string",
        "default": null,
        "expr": "path_extract(algebraicChecks, ['lensLawCheck'])"
      }
    },
    {
      "add_field": {
        "name": "breakingChangeCheck",
        "kind": "string",
        "default": null,
        "expr": "path_extract(algebraicChecks, ['breakingChangeCheck'])"
      }
    }
  ],
  "table": {
    "name": "pipelines",
    "row_struct": "PipelineRow",
    "conflict_keys": ["did", "rkey"],
    "column_defaults": {
      "status": "'pending'"
    }
  }
}
