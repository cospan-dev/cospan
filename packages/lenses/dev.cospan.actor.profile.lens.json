{
  "$type": "panproto.protolens",
  "id": "dev.cospan.actor.profile.db-projection",
  "description": "Lexicon \u2192 appview DB projection for actor profiles",
  "source": "dev.cospan.actor.profile",
  "target": "dev.cospan.actor.profile.view",
  "steps": [
    {
      "remove_field": "avatar"
    },
    {
      "remove_field": "links"
    },
    {
      "add_field": {
        "name": "avatarCid",
        "kind": "string",
        "default": null,
        "expr": "field (field avatar \"ref\") \"$link\""
      }
    }
  ],
  "extensions": {
    "table": {
      "name": "actor_profiles",
      "row_struct": "ActorProfileRow",
      "conflict_keys": [
        "did"
      ],
      "include_rkey": false
    }
  }
}
