{
  "$type": "panproto.protolens",
  "id": "dev.cospan.repo.pull.state.db-projection",
  "description": "Lexicon \u2192 appview DB projection for pull state changes",
  "source": "dev.cospan.repo.pull.state",
  "target": "dev.cospan.repo.pull.state.view",
  "steps": [
    {
      "rename_field": {
        "old": "pull",
        "new": "pullUri"
      }
    }
  ],
  "extensions": {
    "table": {
      "name": "pull_states",
      "row_struct": "PullStateRow",
      "conflict_keys": [
        "did",
        "rkey"
      ]
    }
  }
}
