{
  "$type": "panproto.protolens",
  "id": "dev.panproto.registry.dependency.db-projection",
  "description": "Lexicon \u2192 appview DB projection for cross-schema dependencies",
  "source": "dev.panproto.registry.dependency",
  "target": "dev.panproto.registry.dependency.view",
  "steps": [
    {
      "remove_field": "sourceRepo"
    },
    {
      "remove_field": "targetRepo"
    },
    {
      "add_field": {
        "name": "sourceRepoDid",
        "kind": "string",
        "default": "",
        "expr": "head (split (replace sourceRepo \"at://\" \"\") \"/\")"
      }
    },
    {
      "add_field": {
        "name": "sourceRepoName",
        "kind": "string",
        "default": "",
        "expr": "head (tail (tail (split (replace sourceRepo \"at://\" \"\") \"/\")))"
      }
    },
    {
      "add_field": {
        "name": "targetRepoDid",
        "kind": "string",
        "default": "",
        "expr": "head (split (replace targetRepo \"at://\" \"\") \"/\")"
      }
    },
    {
      "add_field": {
        "name": "targetRepoName",
        "kind": "string",
        "default": "",
        "expr": "head (tail (tail (split (replace targetRepo \"at://\" \"\") \"/\")))"
      }
    }
  ],
  "extensions": {
    "table": {
      "name": "dependencies",
      "row_struct": "DependencyRow",
      "conflict_keys": [
        "did",
        "rkey"
      ]
    }
  }
}
