{
  "$type": "panproto.protolens",
  "id": "dev.cospan.repo.collaborator.db-projection",
  "source": "dev.cospan.repo.collaborator",
  "target": "dev.cospan.repo.collaborator.view",
  "steps": [
    {
      "remove_field": "repo"
    },
    {
      "add_field": {
        "name": "repoDid",
        "kind": "string",
        "default": "",
        "expr": "head (split (replace repo \"at://\" \"\") \"/\")"
      }
    },
    {
      "add_field": {
        "name": "repoName",
        "kind": "string",
        "default": "",
        "expr": "head (tail (tail (split (replace repo \"at://\" \"\") \"/\")))"
      }
    },
    {
      "rename_field": {
        "old": "member",
        "new": "memberDid"
      }
    }
  ],
  "table": {
    "name": "collaborators",
    "row_struct": "CollaboratorRow",
    "conflict_keys": [
      "did",
      "rkey"
    ]
  }
}
