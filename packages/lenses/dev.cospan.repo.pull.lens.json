{
  "$type": "panproto.protolens",
  "id": "dev.cospan.repo.pull.db-projection",
  "description": "Lexicon → appview DB projection for pull requests",
  "source": "dev.cospan.repo.pull",
  "target": "dev.cospan.repo.pull.view",
  "steps": [
    { "remove_field": "repo" },
    { "remove_field": "mergePreview" },
    { "remove_field": "mentions" },
    { "remove_field": "references" },
    {
      "add_field": {
        "name": "repoDid",
        "kind": "string",
        "default": "",
        "expr": "head(split(replace(repo, 'at://', ''), '/'))"
      }
    },
    {
      "add_field": {
        "name": "repoName",
        "kind": "string",
        "default": "",
        "expr": "index(split(replace(repo, 'at://', ''), '/'), 2)"
      }
    },
    {
      "add_field": {
        "name": "state",
        "kind": "string",
        "default": "open"
      }
    },
    {
      "add_field": {
        "name": "commentCount",
        "kind": "integer",
        "default": 0
      }
    }
  ],
  "table": {
    "name": "pulls",
    "row_struct": "PullRow",
    "conflict_keys": ["did", "rkey"],
    "column_defaults": {
      "state": "'open'",
      "commentCount": "0"
    },
    "counter_fields": ["commentCount"]
  }
}
