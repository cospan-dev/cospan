{
  "$type": "panproto.protolens",
  "id": "dev.cospan.repo.issue.db-projection",
  "description": "Lexicon \u2192 appview DB projection for issues",
  "source": "dev.cospan.repo.issue",
  "target": "dev.cospan.repo.issue.view",
  "steps": [
    {
      "remove_field": "repo"
    },
    {
      "remove_field": "schemaRefs"
    },
    {
      "remove_field": "labels"
    },
    {
      "remove_field": "mentions"
    },
    {
      "remove_field": "references"
    },
    {
      "add_field": {
        "name": "repoDid",
        "kind": "string",
        "default": "",
        "expr": "head (split (replace repo \"at://\" \"\") \"/\")"
      }
    },
    {
      "add_field": {
        "name": "repoName",
        "kind": "string",
        "default": "",
        "expr": "head (tail (tail (split (replace repo \"at://\" \"\") \"/\")))"
      }
    },
    {
      "add_field": {
        "name": "state",
        "kind": "string",
        "default": "open"
      }
    },
    {
      "add_field": {
        "name": "commentCount",
        "kind": "integer",
        "default": 0
      }
    }
  ],
  "table": {
    "name": "issues",
    "row_struct": "IssueRow",
    "conflict_keys": [
      "did",
      "rkey"
    ],
    "include_did": true,
    "include_rkey": true,
    "column_defaults": {
      "state": "'open'",
      "commentCount": "0"
    },
    "counter_fields": [
      "commentCount"
    ]
  }
}
