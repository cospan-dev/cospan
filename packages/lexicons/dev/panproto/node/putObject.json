{
  "lexicon": 1,
  "id": "dev.panproto.node.putObject",
  "defs": {
    "main": {
      "type": "procedure",
      "description": "Store a content-addressed object in a node's object store.",
      "parameters": {
        "type": "params",
        "required": ["did", "repo"],
        "properties": {
          "did": { "type": "string", "format": "did", "description": "DID of the repository owner." },
          "repo": { "type": "string", "description": "Repository name." }
        }
      },
      "input": {
        "encoding": "application/vnd.panproto.object+msgpack",
        "description": "The serialized object in msgpack format."
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["id", "stored"],
          "properties": {
            "id": { "type": "string", "description": "Content-addressed ID of the stored object." },
            "stored": { "type": "boolean" }
          }
        }
      }
    }
  }
}
