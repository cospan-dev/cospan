{
  "lexicon": 1,
  "id": "dev.cospan.feed.reaction",
  "defs": {
    "main": {
      "type": "record",
      "key": "tid",
      "record": {
        "type": "object",
        "required": ["subject", "emoji", "createdAt"],
        "properties": {
          "subject": { "type": "string", "format": "at-uri" },
          "emoji": { "type": "string", "maxLength": 16 },
          "createdAt": { "type": "string", "format": "datetime" }
        }
      }
    }
  }
}
