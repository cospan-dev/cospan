{
  "lexicon": 1,
  "id": "dev.cospan.actor.profile",
  "defs": {
    "main": {
      "type": "record",
      "key": "literal:self",
      "record": {
        "type": "object",
        "required": ["bluesky"],
        "properties": {
          "bluesky": { "type": "string", "format": "handle" },
          "displayName": { "type": "string", "maxLength": 64 },
          "description": { "type": "string", "maxLength": 2560 },
          "avatar": { "type": "blob", "accept": ["image/png", "image/jpeg"], "maxSize": 1000000 },
          "links": {
            "type": "array",
            "items": { "type": "ref", "ref": "#link" },
            "maxLength": 10
          }
        }
      }
    },
    "link": {
      "type": "object",
      "required": ["url", "label"],
      "properties": {
        "url": { "type": "string", "format": "uri" },
        "label": { "type": "string", "maxLength": 64 }
      }
    }
  }
}
