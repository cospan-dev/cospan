{
  "lexicon": 1,
  "id": "dev.cospan.auth.ownerAccess",
  "revision": 1,
  "defs": {
    "main": {
      "type": "permission-set",
      "title": "Administer Cospan repositories and organizations",
      "detail": "Maintain Cospan plus: create and settle organizations, transfer or delete repositories, and manage org membership.",
      "includes": ["dev.cospan.auth.maintainerAccess"],
      "permissions": [
        { "type": "permission", "resource": "repo", "collection": "dev.cospan.repo.repo" },
        { "type": "permission", "resource": "repo", "collection": "dev.cospan.org.org" },
        { "type": "permission", "resource": "repo", "collection": "dev.cospan.org.member" },
        { "type": "permission", "resource": "repo", "collection": "dev.cospan.node" }
      ]
    }
  }
}
