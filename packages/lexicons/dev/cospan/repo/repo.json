{
  "lexicon": 1,
  "id": "dev.cospan.repo",
  "defs": {
    "main": {
      "type": "record",
      "key": "any",
      "record": {
        "type": "object",
        "required": ["name", "protocol", "node", "createdAt"],
        "properties": {
          "name": { "type": "string", "maxLength": 128 },
          "description": { "type": "string", "maxLength": 2560 },
          "protocol": { "type": "string", "maxLength": 128 },
          "node": { "type": "string", "format": "at-uri" },
          "defaultBranch": { "type": "string", "maxLength": 256, "default": "main" },
          "visibility": { "type": "string", "knownValues": ["public", "unlisted"] },
          "sourceRepo": { "type": "string", "format": "at-uri" },
          "createdAt": { "type": "string", "format": "datetime" }
        }
      }
    }
  }
}
