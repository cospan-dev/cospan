{
  "lexicon": 1,
  "id": "dev.cospan.repo.issue.comment",
  "defs": {
    "main": {
      "type": "record",
      "key": "tid",
      "record": {
        "type": "object",
        "required": ["issue", "body", "createdAt"],
        "properties": {
          "issue": { "type": "string", "format": "at-uri" },
          "body": { "type": "string", "maxLength": 100000 },
          "schemaRefs": {
            "type": "array",
            "items": { "type": "ref", "ref": "dev.cospan.repo.issue#schemaRef" },
            "maxLength": 20
          },
          "mentions": {
            "type": "array",
            "items": { "type": "string", "format": "did" },
            "maxLength": 50
          },
          "createdAt": { "type": "string", "format": "datetime" }
        }
      }
    }
  }
}
