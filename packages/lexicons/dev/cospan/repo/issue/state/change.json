{
  "lexicon": 1,
  "id": "dev.cospan.repo.issue.state.change",
  "defs": {
    "main": {
      "type": "procedure",
      "input": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["issue", "state", "did"],
          "properties": {
            "issue": { "type": "string", "format": "at-uri" },
            "state": { "type": "string", "knownValues": ["open", "closed"] },
            "reason": { "type": "string" },
            "did": { "type": "string", "format": "did" }
          }
        }
      }
    }
  }
}
