{
  "lexicon": 1,
  "id": "dev.cospan.repo.create",
  "defs": {
    "main": {
      "type": "procedure",
      "input": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["did", "name"],
          "properties": {
            "did": { "type": "string", "format": "did" },
            "name": { "type": "string" },
            "description": { "type": "string" },
            "protocol": { "type": "string" },
            "visibility": { "type": "string" }
          }
        }
      }
    }
  }
}
