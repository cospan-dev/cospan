{
  "lexicon": 1,
  "id": "sh.tangled.sync.requestCrawl",
  "defs": {
    "main": {
      "type": "procedure",
      "description": "Request a service to persistently crawl hosted repos. Does not require auth.",
      "input": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["hostname"],
          "properties": {
            "hostname": {
              "type": "string",
              "description": "Hostname of the current service (eg, Knot) that is requesting to be crawled."
            },
            "ensureRepo": {
              "type": "string",
              "format": "at-uri",
              "description": "specific repository to ensure crawling"
            }
          }
        }
      },
      "errors": [{ "name": "HostBanned" }]
    }
  }
}
